<script>
  var activeProng = 'all';
  var activeCircuit = 'all';
  function applyFilters(){
    var cards = document.querySelectorAll('.case-card');
    cards.forEach(function(c){
      var prong = c.getAttribute('data-prong');
      var circuit = c.getAttribute('data-circuit');
      var prongOk = activeProng === 'all' || prong === activeProng;
      var circuitOk = activeCircuit === 'all' || circuit === activeCircuit || (activeCircuit === 'other' && circuit !== '8' && circuit !== '10');
      if(prongOk && circuitOk){ c.classList.remove('hidden'); } else { c.classList.add('hidden'); }
    });
  }
  function setProng(p){
    activeProng = p;
    document.querySelectorAll('[data-filter-prong]').forEach(function(b){
      b.classList.toggle('active', b.getAttribute('data-filter-prong') === p);
    });
    applyFilters();
  }
  function setCircuit(c){
    activeCircuit = c;
    document.querySelectorAll('[data-filter-circuit]').forEach(function(b){
      b.classList.toggle('active', b.getAttribute('data-filter-circuit') === c);
    });
    applyFilters();
  }
</script>
</body>
</html>
